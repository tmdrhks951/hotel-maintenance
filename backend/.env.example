NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/hotel_maintenance

# Redis (선택 — 없으면 전화번호 인증코드가 인메모리 폴백으로 동작, 단일 인스턴스 한정)
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# 파일 저장
#  - local : 디스크 저장 (UPLOAD_DIR, 컨테이너 배포 시 영구 볼륨 필수)
#  - minio : S3 호환 오브젝트 스토리지 (MinIO / AWS S3 / Cloudflare R2)
# ─────────────────────────────────────────────
STORAGE_DRIVER=local
# UPLOAD_DIR=/data/uploads

# STORAGE_DRIVER=minio 일 때만 사용
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hotel-files
# 공개 URL 베이스 (CDN/R2 퍼블릭 도메인). 미설정 시 endpoint 기반 자동 생성
# MINIO_PUBLIC_URL=https://files.example.com

# ─────────────────────────────────────────────
# SMS 발송 (전화번호 인증)
#  - none  : 미연동 — 개발 환경에서는 코드가 응답에 포함되어 테스트 가능, 프로덕션에서는 503
#  - aligo : 알리고(smartsms.aligo.in) 문자 API
# ─────────────────────────────────────────────
SMS_PROVIDER=none
# ALIGO_API_KEY=your-aligo-api-key
# ALIGO_USER_ID=your-aligo-user-id
# SMS_SENDER=01000000000   # 알리고에 사전 등록된 발신번호

# CORS
CORS_ORIGIN=http://localhost:3000

# JWT — 반드시 32자 이상, access/refresh 시크릿은 서로 다른 값 사용
JWT_ACCESS_SECRET=your-access-secret-key-must-be-at-least-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-must-be-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# bcrypt
BCRYPT_ROUNDS=12

# 최초 배포 시 관리자 부트스트랩 (관리자 계정이 없을 때만 1회 생성 — 생성 후 제거 권장)
# ADMIN_LOGIN_ID=admin
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me-10-chars-min
