NODE_ENV=development
PORT=4000

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/hotel_maintenance

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=hotel-files

# CORS
CORS_ORIGIN=http://localhost:3000

# JWT — 반드시 32자 이상, access/refresh 시크릿은 서로 다른 값 사용
JWT_ACCESS_SECRET=your-access-secret-key-must-be-at-least-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-must-be-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# bcrypt
BCRYPT_ROUNDS=12
